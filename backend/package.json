{
  "name": "review-pulse-backend",
  "version": "1.0.0",
  "description": "Backend API Gateway for Review Pulse system",
  "main": "src/main.py",
  "scripts": {
    "dev": "uvicorn src.main:app --reload --host 0.0.0.0 --port 9000",
    "start": "uvicorn src.main:app --host 0.0.0.0 --port 9000",
    "test": "pytest",
    "test:watch": "pytest --watch",
    "test:coverage": "pytest --cov=src --cov-report=html",
    "lint": "flake8 src/ tests/",
    "lint:fix": "autopep8 --in-place --recursive src/ tests/",
    "format": "black src/ tests/",
    "migrate": "alembic upgrade head",
    "migrate:create": "alembic revision --autogenerate -m",
    "shell": "python -i -c 'from src.database import engine; from src.models import Base; Base.metadata.create_all(engine)'",
    "worker": "celery -A src.tasks worker --loglevel=info",
    "beat": "celery -A src.tasks beat --loglevel=info",
    "docker:build": "docker build -t reviewpulse/backend .",
    "docker:run": "docker run -p 9000:9000 reviewpulse/backend"
  },
  "dependencies": {
    "fastapi": "^0.104.1",
    "uvicorn[standard]": "^0.24.0",
    "pydantic": "^2.5.0",
    "sqlalchemy": "^2.0.23",
    "alembic": "^1.12.1",
    "psycopg2-binary": "^2.9.9",
    "redis": "^5.0.1",
    "celery": "^5.3.4",
    "python-jose[cryptography]": "^3.3.0",
    "passlib[bcrypt]": "^1.7.4",
    "python-multipart": "^0.0.6",
    "aiofiles": "^23.2.1",
    "httpx": "^0.25.2",
    "structlog": "^23.2.0",
    "prometheus-client": "^0.19.0",
    "sentry-sdk": "^1.38.0",
    "python-dotenv": "^1.0.0",
    "pyyaml": "^6.0.1",
    "jinja2": "^3.1.2",
    "email-validator": "^2.1.0",
    "asyncpg": "^0.29.0",
    "aioredis": "^2.0.1"
  },
  "devDependencies": {
    "pytest": "^7.4.3",
    "pytest-asyncio": "^0.21.1",
    "pytest-cov": "^4.1.0",
    "pytest-mock": "^3.12.0",
    "httpx": "^0.25.2",
    "flake8": "^6.1.0",
    "autopep8": "^2.0.4",
    "black": "^23.11.0",
    "mypy": "^1.7.1",
    "pre-commit": "^3.5.0"
  },
  "engines": {
    "python": ">=3.11"
  },
  "keywords": [
    "fastapi",
    "python",
    "api",
    "microservices",
    "review-pulse",
    "product-reviews"
  ],
  "author": "Akash1122-cl",
  "license": "MIT"
}
