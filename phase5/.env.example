# Google API Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/callback

# MCP Server Configuration
MCP_DOCS_PORT=8001
MCP_GMAIL_PORT=8002
MCP_HOST=localhost
MCP_PROTOCOL_VERSION=0.2.0

# Email Configuration
DEFAULT_SENDER_EMAIL=your-email@example.com
EMAIL_SUBJECT_PREFIX=Review Pulse Report
EMAIL_SIGNATURE=Generated by Review Pulse System

# OAuth Configuration
OAUTH_STATE_SECRET=your_random_secret_string_here
TOKEN_ENCRYPTION_KEY=your_32_char_encryption_key_here

# Database Configuration (for storing tokens and stakeholders)
DB_PASSWORD=your_db_password
REDIS_PASSWORD=your_redis_password

# Security
JWT_SECRET=your_jwt_secret_for_mcp_servers

# Environment
ENVIRONMENT=development
DEBUG=true

# Rate Limiting
GMAIL_RATE_LIMIT_PER_MINUTE=50
DOCS_RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/phase5.log
