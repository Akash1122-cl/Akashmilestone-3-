# Database Configuration
DB_PASSWORD=your_db_password

# Redis Configuration
REDIS_PASSWORD=your_redis_password

# PAID API KEYS - Optional, only needed if use_llm=true in config.yaml
# OpenAI API Key (for GPT-4 theme analysis) - Paid service
# OPENAI_API_KEY=your_openai_api_key

# JWT Secret (if authentication enabled)
JWT_SECRET=your_jwt_secret

# Environment
ENVIRONMENT=development

# NOTE: Phase 3 runs in FREE-ONLY mode by default using:
# - Template-based theme names and descriptions (no LLM API costs)
# - UMAP + HDBSCAN clustering (fully local, open source)
# Set use_llm=true in config.yaml only if you have API credits to use
