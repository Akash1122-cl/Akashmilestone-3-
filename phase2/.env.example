# Database Configuration
DB_PASSWORD=your_db_password

# Redis Configuration
REDIS_PASSWORD=your_redis_password

# PAID API KEYS - Optional, only needed if use_api=true in config.yaml
# Google Gemini API Key (for embeddings) - Paid service
# GEMINI_API_KEY=your_gemini_api_key

# OpenAI API Key (for embeddings) - Paid service
# OPENAI_API_KEY=your_openai_api_key

# Chroma Cloud Configuration - Optional, local mode is free
# CHROMA_CLOUD_API_KEY=your_chroma_cloud_api_key
# CHROMA_CLOUD_TENANT_ID=your_tenant_id
# CHROMA_CLOUD_HOST=https://api.trychroma.com

# JWT Secret (if authentication enabled)
JWT_SECRET=your_jwt_secret

# Environment
ENVIRONMENT=development

# NOTE: This project runs in FREE-ONLY mode by default using:
# - sentence-transformers (local embeddings, no API key needed)
# - Local ChromaDB (no cloud costs)
# - Template-based theme analysis (no LLM API costs)
# Set use_api=true in config.yaml only if you have API credits to use
